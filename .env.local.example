# ─── Supabase ──────────────────────────────────────────────────────────
# Project Settings → API → Project URL and anon/public key.
# Copy this file to `.env.local` and fill in your own values.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Site URL (used for password-reset email redirects). Localhost in dev,
# your Vercel URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Error alerts: Sentry (optional) ───────────────────────────────────
# From your Sentry project → Settings → Client Keys (DSN). Leave blank to disable.
NEXT_PUBLIC_SENTRY_DSN=
# Only needed to upload source maps (nicer stack traces). Optional.
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ─── Rate limiting: Upstash Redis (optional) ───────────────────────────
# From Upstash → your Redis database → REST API. Leave blank to disable.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
